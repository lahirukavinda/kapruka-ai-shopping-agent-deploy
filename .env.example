# Option 1: GitHub Models (free — GPT-5 mini, GPT-4o-mini via GitHub PAT)
GITHUB_TOKEN=your-github-personal-access-token

# Option 2: OpenAI directly (requires paid plan)
# OPENAI_API_KEY=your-openai-api-key

# Model selection — change via env var, no code changes needed.
# GitHub Models free tier: gpt-4o-mini (150 req/day), gpt-4o (50 req/day)
# GitHub Models Copilot Pro: gpt-5-mini (12 req/day, requires $10/mo subscription)
# OpenAI direct (OPENAI_API_KEY): gpt-4o-mini-direct, gpt-4o-direct (128K+ context)
# Each model has preconfigured token budgets in src/app/api/chat/route.ts
AI_MODEL=gpt-4o-mini

KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp
NEXT_PUBLIC_APP_NAME=Aura ඕරා
NEXT_PUBLIC_DEFAULT_CURRENCY=LKR
